#!/bin/bash
# paper_agent - 论文助手组合脚本
# 串联使用 psum (总结) 和 pask (提问)

set -e

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

print_header() {
    echo ""
    echo "================================================================================"
    echo "$1"
    echo "================================================================================"
    echo ""
}

# 显示帮助
show_help() {
    cat << EOF
📄 论文助手 - 论文总结 + 提问组合工具

用法:
  paper_agent run <pdf文件>                    # 完整流程：总结后进入提问模式
  paper_agent run <pdf文件> -o <md文件>        # 指定输出的MD文件
  paper_agent model list                       # 列出可用模型
  paper_agent model set <模型名>               # 同时设置总结和提问模型
  paper_agent model set-sum <模型名>           # 仅设置总结模型 (psum)
  paper_agent model set-ask <模型名>           # 仅设置提问模型 (pask)
  paper_agent model current                    # 查看当前模型配置
  paper_agent psum <pdf文件>                   # 仅运行总结
  paper_agent pask <md文件>                    # 仅运行提问模式

示例:
  paper_agent run paper.pdf                    # 完整流程
  paper_agent run paper.pdf -o summary.md     # 指定输出文件
  paper_agent model set deepseek              # 同时设置两个模型
  paper_agent model set-sum gpt4               # 仅设置总结模型
  paper_agent model set-ask claude-opus        # 仅设置提问模型

EOF
}

# 模型管理
model_list() {
    print_header "可用模型列表"
    psum model list
}

model_set_both() {
    local model_name="$1"
    print_info "同时设置总结模型和提问模型为: $model_name"

    # 检查模型是否存在
    psum model set "$model_name" 2>/dev/null || {
        print_error "模型不存在或设置失败"
        exit 1
    }

    pask model set "$model_name"
    print_success "总结和提问模型都已设置为: $model_name"
}

model_set_sum() {
    local model_name="$1"
    print_info "设置总结模型为: $model_name"
    psum model set "$model_name"
}

model_set_ask() {
    local model_name="$1"
    print_info "设置提问模型为: $model_name"
    pask model set "$model_name"
}

model_current() {
    print_header "当前模型配置"
    echo -e "${BLUE}总结模型 (psum):${NC}"
    psum model current 2>/dev/null || print_warning "未设置"
    echo ""
    echo -e "${BLUE}提问模型 (pask):${NC}"
    pask model current 2>/dev/null || print_warning "未设置"
    echo ""
}

# 仅运行总结
run_psum() {
    local pdf_file="$1"
    local output_file="$2"

    print_header "📄 步骤 1/1: 生成论文总结"
    print_info "输入文件: $pdf_file"

    if [ -n "$output_file" ]; then
        psum run "$pdf_file" -o "$output_file"
    else
        psum run "$pdf_file"
    fi
}

# 仅运行提问
run_pask() {
    local md_file="$1"

    print_header "📝 步骤 2/2: 启动提问模式"
    print_info "总结文件: $md_file"

    pask run "$md_file"
}

# 完整流程
run_full() {
    local pdf_file="$1"
    local output_file="$2"

    # 检查PDF文件是否存在
    if [ ! -f "$pdf_file" ]; then
        print_error "文件不存在: $pdf_file"
        exit 1
    fi

    # 步骤1: 生成总结
    print_header "📄 步骤 1/2: 生成论文总结"
    print_info "输入文件: $pdf_file"

    if [ -n "$output_file" ]; then
        psum run "$pdf_file" -o "$output_file"
        summary_file="$output_file"
    else
        # 自动生成输出文件名
        local basename=$(basename "$pdf_file" .pdf)
        psum run "$pdf_file"
        summary_file="${basename} 总结.md"
    fi

    echo ""
    read -p "$(echo -e ${GREEN}按 Enter 继续，或 Ctrl+C 退出...${NC})"

    # 步骤2: 启动提问模式
    print_header "📝 步骤 2/2: 启动提问模式"
    print_info "总结文件: $summary_file"

    pask run "$summary_file"
}

# 主逻辑
main() {
    # 如果没有参数或为help，显示帮助
    case "$1" in
        help|--help|-h|"")
            show_help
            return
            ;;
    esac

    # 如果第一个参数是 .pdf 文件，默认执行 run
    if [[ "$1" == *.pdf ]]; then
        local pdf_file="$1"
        local output_file=""

        # 检查 -o 参数
        if [ "$2" = "-o" ] && [ -n "$3" ]; then
            output_file="$3"
        fi
        run_full "$pdf_file" "$output_file"
        return
    fi

    # 如果第一个参数是 .md 文件，默认执行 pask
    if [[ "$1" == *.md ]]; then
        local md_file="$1"
        run_pask "$md_file"
        return
    fi

    # 命令模式
    case "$1" in
        model)
            case "$2" in
                list)
                    model_list
                    ;;
                set)
                    if [ -z "$3" ]; then
                        print_error "请指定模型名"
                        exit 1
                    fi
                    model_set_both "$3"
                    ;;
                set-sum)
                    if [ -z "$3" ]; then
                        print_error "请指定模型名"
                        exit 1
                    fi
                    model_set_sum "$3"
                    ;;
                set-ask)
                    if [ -z "$3" ]; then
                        print_error "请指定模型名"
                        exit 1
                    fi
                    model_set_ask "$3"
                    ;;
                current)
                    model_current
                    ;;
                *)
                    print_error "未知命令: paper_agent model $2"
                    echo "可用选项: list, set, set-sum, set-ask, current"
                    exit 1
                    ;;
            esac
            ;;
        psum)
            if [ -z "$2" ]; then
                print_error "请指定PDF文件"
                exit 1
            fi
            run_psum "$2"
            ;;
        pask)
            if [ -z "$2" ]; then
                print_error "请指定MD文件"
                exit 1
            fi
            run_pask "$2"
            ;;
        run)
            if [ -z "$2" ]; then
                print_error "请指定PDF文件"
                exit 1
            fi
            if [ "$2" = "-o" ] && [ -n "$3" ]; then
                # 错误情况：psum <pdf_file> 而不是 run <pdf_file>
                print_error "使用方法: paper_agent run <pdf_file> -o <output_file>"
                exit 1
            fi
            # 解析 -o 参数
            local output_file=""
            if [ "$3" = "-o" ] && [ -n "$4" ]; then
                output_file="$4"
            fi
            run_full "$2" "$output_file"
            ;;
        *)
            print_error "未知命令: $1"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
